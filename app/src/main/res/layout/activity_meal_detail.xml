<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/meal_detail_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary">

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <!-- Meal Image -->
            <ImageView
                android:id="@+id/meal_image"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:scaleType="centerCrop"
                android:adjustViewBounds="true"
                android:layout_marginBottom="16dp"
                android:contentDescription="Meal Image" />

            <!-- Meal Name -->
            <TextView
                android:id="@+id/meal_name"
                style="@style/NormalText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingBottom="8dp"
                android:text="Meal Name"
                android:textColor="@color/secondary"
                android:textSize="24sp"
                android:textStyle="bold" />

            <!-- Meal Name Edit -->
            <EditText
                android:id="@+id/edit_meal_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Meal Name"
                android:textSize="20sp"
                android:textColor="@color/secondary"
                android:visibility="gone" />

            <!-- Meal Description -->
            <TextView
                android:id="@+id/meal_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Meal description here"
                android:textSize="16sp"
                android:textColor="@color/secondary2"
                android:paddingBottom="16dp" />

            <!-- Meal Description Edit -->
            <EditText
                android:id="@+id/edit_meal_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/secondary2"
                android:hint="Meal Description"
                android:textSize="16sp"
                android:visibility="gone" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/secondary"
                android:layout_marginBottom="16dp" />

            <!-- Ingredients Toggle -->
            <LinearLayout
                android:id="@+id/ingredientsToggle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/toggle_all_corners"
                android:clickable="true"
                android:focusable="true"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingTop="12dp"
                android:paddingEnd="8dp"
                android:paddingBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    style="@style/NormalText"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Ingredients"
                    android:textColor="@color/secondary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/ingredientsArrow"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="8dp"
                    android:rotation="0"
                    android:src="@drawable/ic_arrow_down_24" />
            </LinearLayout>

            <FrameLayout
                android:id="@+id/ingredient_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:background="@drawable/ingredients_and_recipe_background" >

                <!-- Ingredients List -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/ingredients_recycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:layout_marginBottom="8dp" />

                <androidx.core.widget.NestedScrollView
                    android:id="@+id/edit_ingredients_scroll_View"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    >
                    <!-- Editable Ingredients Container -->
                    <LinearLayout
                        android:id="@+id/edit_ingredients_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"
                        android:layout_marginBottom="8dp" />
                </androidx.core.widget.NestedScrollView>

            </FrameLayout>


            <!-- Add Ingredient Button (edit mode only) -->
            <Button
                style="@style/NormalButtonSecondary"
                android:id="@+id/btn_add_ingredient"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="+ Add Ingredient"
                android:layout_marginBottom="0dp"
                android:visibility="gone" />

            <!-- Recipe Toggle -->
            <LinearLayout
                android:id="@+id/recipeToggle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/toggle_all_corners"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="12dp">

                <TextView
                    android:layout_width="0dp"
                    style="@style/NormalText"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Recipe"
                    android:textColor="@color/secondary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/recipeArrow"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="4dp"
                    android:rotation="0"
                    android:src="@drawable/ic_arrow_down_24" />
            </LinearLayout>

            <!-- Recipe Text -->
            <FrameLayout
                android:id="@+id/recipe_container"
                android:layout_width="match_parent"
                android:layout_height="500dp"
                android:background="@drawable/ingredients_and_recipe_background"
                android:layout_marginTop="0dp"
                android:visibility="gone">

                <androidx.core.widget.NestedScrollView
                    android:id="@+id/recipe_scroll_view"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scrollbars="vertical">

                    <TextView
                        android:id="@+id/recipe_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="12dp"
                        android:text="Recipe steps..."
                        android:textSize="16sp"
                        android:textColor="@color/secondary2" />
                </androidx.core.widget.NestedScrollView>

                <androidx.core.widget.NestedScrollView
                    android:id="@+id/edit_recipe_scroll_view"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="gone"
                    android:scrollbars="vertical">

                    <!-- Recipe Edit -->
                    <EditText
                        android:id="@+id/edit_recipe_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone"
                        android:hint="Edit recipe steps..."
                        android:padding="12dp"
                        android:textSize="16sp"
                        android:textColor="@color/secondary2" />
                </androidx.core.widget.NestedScrollView>


            </FrameLayout>





            <!-- Save Changes Button (edit mode only) -->
            <Button
                style="@style/NormalButtonPrimary"
                android:id="@+id/btn_save_changes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Save Changes"
                android:visibility="gone"
                android:layout_marginTop="24dp"
                android:backgroundTint="@color/secondary"
                android:textColor="@android:color/white" />

            <!-- Share Ingredients Button -->
            <Button
                style="@style/NormalButtonPrimary"
                android:id="@+id/btn_share_ingredients"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Share Ingredients"
                android:layout_marginTop="20dp"
                android:backgroundTint="@color/secondary"
                android:textColor="@android:color/white"
                android:drawableStart="@drawable/share_24px"
                android:drawablePadding="8dp"
                android:padding="12dp" />
        </LinearLayout>
    </ScrollView>

    <!-- Delete FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_delete"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="80dp"
        android:visibility="gone"
        android:src="@drawable/delete_24px"
        android:contentDescription="Delete"
        app:backgroundTint="@color/red"
        app:tint="@android:color/white"
        app:fabSize="mini" />

    <!-- Edit FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_edit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="50dp"
        android:visibility="gone"
        android:src="@drawable/edit_24px"
        android:contentDescription="Edit"
        app:backgroundTint="@color/tertiary"
        app:tint="@android:color/white"
        app:fabSize="mini" />

    <!-- Main FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_main"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:src="@drawable/menu_24px"
        android:contentDescription="Menu"
        app:backgroundTint="@color/secondary"
        app:tint="@android:color/white" />
</FrameLayout>
